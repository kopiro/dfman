#!/bin/bash

set -e

CONFIG_FILE="$HOME/.config/dfman.conf"
DFMAN_UPDATE_URL="https://raw.githubusercontent.com/kopiro/dfman/main/dfman"
CONFIG_SOURCES=()
CONFIG_TARGETS=()

usage() {
    echo "Usage: dfman <create|link|doctor|repo-add|repo-rm|repo-sync|self-update> [options]"
    echo ""
    echo "Config:"
    echo "  $CONFIG_FILE"
    echo ""
    echo "Commands:"
    echo "  link [-f] [--dry-run] [--repo r] Symlink dotfiles to target directory"
    echo "  create --repo r path Import a file into dotfiles"
    echo "  doctor [--repo repo] Find broken symlinks"
    echo "  repo-add <src> [tgt] Add a source to the config"
    echo "  repo-rm <source>     Remove a source from the config"
    echo "  repo-sync [--repo r] Commit, pull, and push repos"
    echo "  self-update          Update dfman from GitHub"
    exit 1
}

expand_home() {
    local path="$1"

    case "$path" in
        "~")
            echo "$HOME"
            ;;
        "~/"*)
            echo "$HOME/${path#\~/}"
            ;;
        "$HOME/~")
            echo "$HOME"
            ;;
        "$HOME/~/"*)
            # If a caller or existing config accidentally produced "$HOME/~/x",
            # treat it as "~/x" instead of looking for a literal "~" directory.
            echo "$HOME/${path#"$HOME/~/"}"
            ;;
        *)
            echo "$path"
            ;;
    esac
}

normalize_dir() {
    local dir="$1"

    # Keep root as "/" but remove trailing slashes elsewhere so target prefix
    # matching behaves consistently for paths from the config file.
    while [ "$dir" != "/" ] && [ "${dir%/}" != "$dir" ]; do
        dir="${dir%/}"
    done

    echo "$dir"
}

validate_config_path() {
    local path="$1"
    local kind="$2"
    local location="$3"

    if [[ "$path" != /* ]]; then
        echo "Error: $kind must be absolute or start with ~ in $location"
        exit 1
    fi
}

validate_config_value() {
    local value="$1"
    local kind="$2"

    # Config entries are whitespace-delimited and use # for comments. Rejecting
    # those characters keeps repo-add from writing lines dfman cannot read back.
    if [[ "$value" =~ [[:space:]] ]] || [[ "$value" == *"#"* ]]; then
        echo "Error: $kind cannot contain whitespace or #"
        exit 1
    fi
}

current_executable_path() {
    local script_path="${BASH_SOURCE[0]}"

    if [[ "$script_path" != */* ]]; then
        script_path=$(command -v "$script_path")
    fi

    if [[ "$script_path" != /* ]]; then
        script_path="$(pwd)/$script_path"
    fi

    # Follow symlinks so self-update refreshes the actual installed script,
    # not just the launcher path used to invoke it.
    while [ -L "$script_path" ]; do
        local link_target
        link_target=$(readlink "$script_path")

        if [[ "$link_target" == /* ]]; then
            script_path="$link_target"
        else
            script_path="$(cd "$(dirname "$script_path")" && pwd)/$link_target"
        fi
    done

    local script_dir
    script_dir=$(cd "$(dirname "$script_path")" && pwd)

    echo "$script_dir/$(basename "$script_path")"
}

load_config() {
    CONFIG_SOURCES=()
    CONFIG_TARGETS=()

    if [ ! -f "$CONFIG_FILE" ]; then
        echo "Error: config file not found: $CONFIG_FILE"
        exit 1
    fi

    local line
    local line_number=0
    local source_dir
    local target_dir
    local extra

    while IFS= read -r line || [ -n "$line" ]; do
        line_number=$((line_number + 1))

        # The config is intentionally line-oriented to keep dfman dependency
        # free. Each non-comment line is: source [target].
        line="${line%%#*}"
        read -r source_dir target_dir extra <<< "$line"

        if [ -z "$source_dir" ]; then
            continue
        fi

        if [ -n "$extra" ]; then
            echo "Error: too many fields in $CONFIG_FILE:$line_number"
            exit 1
        fi

        if [ -z "$target_dir" ]; then
            target_dir="~"
        fi

        source_dir=$(normalize_dir "$(expand_home "$source_dir")")
        target_dir=$(normalize_dir "$(expand_home "$target_dir")")

        validate_config_path "$source_dir" "source" "$CONFIG_FILE:$line_number"
        validate_config_path "$target_dir" "target" "$CONFIG_FILE:$line_number"

        CONFIG_SOURCES+=("$source_dir")
        CONFIG_TARGETS+=("$target_dir")
    done < "$CONFIG_FILE"

    if [ "${#CONFIG_SOURCES[@]}" -eq 0 ]; then
        echo "Error: config file must define at least one source"
        exit 1
    fi
}

config_entry_exists() {
    local source_to_add="$1"
    local target_to_add="$2"

    if [ ! -f "$CONFIG_FILE" ]; then
        return 1
    fi

    local line
    local line_number=0
    local source_dir
    local target_dir
    local extra

    while IFS= read -r line || [ -n "$line" ]; do
        line_number=$((line_number + 1))
        line="${line%%#*}"
        read -r source_dir target_dir extra <<< "$line"

        if [ -z "$source_dir" ]; then
            continue
        fi

        if [ -n "$extra" ]; then
            echo "Error: too many fields in $CONFIG_FILE:$line_number"
            exit 1
        fi

        if [ -z "$target_dir" ]; then
            target_dir="~"
        fi

        source_dir=$(normalize_dir "$(expand_home "$source_dir")")
        target_dir=$(normalize_dir "$(expand_home "$target_dir")")

        validate_config_path "$source_dir" "source" "$CONFIG_FILE:$line_number"
        validate_config_path "$target_dir" "target" "$CONFIG_FILE:$line_number"

        if [ "$source_dir" = "$source_to_add" ] && [ "$target_dir" = "$target_to_add" ]; then
            return 0
        fi
    done < "$CONFIG_FILE"

    return 1
}

require_source_exists() {
    local source_dir="$1"

    if [ ! -d "$source_dir" ]; then
        echo "Error: source directory does not exist: $source_dir"
        exit 1
    fi
}

require_all_sources_exist() {
    local source_dir

    for source_dir in "${CONFIG_SOURCES[@]}"; do
        require_source_exists "$source_dir"
    done
}

path_is_under_target() {
    local full_path="$1"
    local target_dir="$2"

    if [ "$target_dir" = "/" ]; then
        [[ "$full_path" == /* ]]
    else
        [[ "$full_path" == "$target_dir"/* ]]
    fi
}

relative_path_from_target() {
    local full_path="$1"
    local target_dir="$2"

    if [ "$target_dir" = "/" ]; then
        echo "${full_path#/}"
    else
        echo "${full_path#$target_dir/}"
    fi
}

select_config_for_repo() {
    local repo_arg="$1"
    local repo_dir
    local index

    repo_dir=$(normalize_dir "$(expand_home "$repo_arg")")
    validate_config_path "$repo_dir" "repo" "repo argument"

    SELECTED_SOURCE_DIR=""
    SELECTED_TARGET_DIR=""

    for index in "${!CONFIG_SOURCES[@]}"; do
        if [ "${CONFIG_SOURCES[$index]}" = "$repo_dir" ]; then
            SELECTED_SOURCE_DIR="${CONFIG_SOURCES[$index]}"
            SELECTED_TARGET_DIR="${CONFIG_TARGETS[$index]}"
            return
        fi
    done

    echo "Error: repo is not configured: $repo_arg"
    exit 1
}

link_source() {
    local source_dir="$1"
    local target_dir="$2"
    local force="$3"
    local dry_run="$4"

    echo "Linking source: $source_dir -> $target_dir"

    find "$source_dir" -mindepth 1 -maxdepth 1 | while read -r dotfile; do
        relative_path="${dotfile#$source_dir/}"

        # Handle files with # in name (treat as directory separator)
        if [[ "$relative_path" == *"#"* ]]; then
            target_path="${relative_path//#//}"
            symlink_target="$target_dir/$target_path"

            target_parent_dir=$(dirname "$symlink_target")
            if [ "$dry_run" = true ]; then
                echo "Would create directory: $target_parent_dir"
            else
                mkdir -p "$target_parent_dir"
            fi
        else
            symlink_target="$target_dir/$relative_path"
        fi

        # Skip if already a symlink
        if [ -L "$symlink_target" ]; then
            current_target=$(readlink "$symlink_target")
            if [ "$current_target" != "$dotfile" ]; then
                echo -e "\033[33mWarning: <$symlink_target> points to <$current_target>\033[0m"
                if [ "$force" = true ]; then
                    if [ "$dry_run" = true ]; then
                        echo "Would remove symlink: $symlink_target"
                        echo "Would link: $dotfile -> $symlink_target"
                        continue
                    fi

                    read -p "Delete and replace? [y/N] " confirm < /dev/tty
                    if [[ "$confirm" =~ ^[Yy]$ ]]; then
                        rm "$symlink_target"
                    else
                        continue
                    fi
                else
                    continue
                fi
            else
                continue
            fi
        fi

        if [ -d "$symlink_target" ]; then
            echo -e "\033[33mWarning: <$symlink_target> is a directory\033[0m"
            if [ "$force" = true ]; then
                if [ "$dry_run" = true ]; then
                    echo "Would remove directory: $symlink_target"
                    echo "Would link: $dotfile -> $symlink_target"
                    continue
                fi

                read -p "Delete and replace? [y/N] " confirm < /dev/tty
                if [[ "$confirm" =~ ^[Yy]$ ]]; then
                    rm -rf "$symlink_target"
                else
                    continue
                fi
            else
                continue
            fi
        fi

        if [ -f "$symlink_target" ]; then
            echo -e "\033[33mWarning: <$symlink_target> is a file\033[0m"
            if [ "$force" = true ]; then
                if [ "$dry_run" = true ]; then
                    echo "Would remove file: $symlink_target"
                    echo "Would link: $dotfile -> $symlink_target"
                    continue
                fi

                read -p "Delete and replace? [y/N] " confirm < /dev/tty
                if [[ "$confirm" =~ ^[Yy]$ ]]; then
                    rm "$symlink_target"
                else
                    continue
                fi
            else
                continue
            fi
        fi

        if [ "$dry_run" = true ]; then
            echo "Would link: $dotfile -> $symlink_target"
        else
            echo "Linking: $dotfile -> $symlink_target"
            ln -s "$dotfile" "$symlink_target"
        fi
    done
}

cmd_link() {
    FORCE=false
    DRY_RUN=false
    local repo_arg=""

    while [ "$#" -gt 0 ]; do
        case "$1" in
            -f)
                FORCE=true
                shift
                ;;
            --dry-run)
                DRY_RUN=true
                shift
                ;;
            --repo)
                if [ -z "${2:-}" ]; then
                    echo "Usage: dfman link [-f] [--dry-run] [--repo <source>]"
                    exit 1
                fi
                repo_arg="$2"
                shift 2
                ;;
            --repo=*)
                repo_arg="${1#--repo=}"
                if [ -z "$repo_arg" ]; then
                    echo "Usage: dfman link [-f] [--dry-run] [--repo <source>]"
                    exit 1
                fi
                shift
                ;;
            *)
                echo "Usage: dfman link [-f] [--dry-run] [--repo <source>]"
                exit 1
                ;;
        esac
    done

    if [ "$FORCE" = true ]; then
        echo "Force mode enabled"
    fi

    if [ "$DRY_RUN" = true ]; then
        echo "Dry run enabled"
    fi

    load_config
    if [ -n "$repo_arg" ]; then
        select_config_for_repo "$repo_arg"
        require_source_exists "$SELECTED_SOURCE_DIR"
        link_source "$SELECTED_SOURCE_DIR" "$SELECTED_TARGET_DIR" "$FORCE" "$DRY_RUN"
    else
        require_all_sources_exist

        local index
        for index in "${!CONFIG_SOURCES[@]}"; do
            link_source "${CONFIG_SOURCES[$index]}" "${CONFIG_TARGETS[$index]}" "$FORCE" "$DRY_RUN"
        done
    fi

    if [ "$DRY_RUN" = true ]; then
        echo "Dry run completed"
    else
        echo "Dotfiles linked successfully"
    fi
}

cmd_create() {
    local repo_arg=""
    local full_path=""

    while [ "$#" -gt 0 ]; do
        case "$1" in
            --repo)
                if [ -z "${2:-}" ]; then
                    echo "Usage: dfman create --repo <source> <absolute-path>"
                    exit 1
                fi
                repo_arg="$2"
                shift 2
                ;;
            --repo=*)
                repo_arg="${1#--repo=}"
                if [ -z "$repo_arg" ]; then
                    echo "Usage: dfman create --repo <source> <absolute-path>"
                    exit 1
                fi
                shift
                ;;
            --*)
                echo "Usage: dfman create --repo <source> <absolute-path>"
                exit 1
                ;;
            *)
                if [ -n "$full_path" ]; then
                    echo "Usage: dfman create --repo <source> <absolute-path>"
                    exit 1
                fi
                full_path="$1"
                shift
                ;;
        esac
    done

    if [ -z "$repo_arg" ] || [ -z "$full_path" ]; then
        echo "Usage: dfman create --repo <source> <absolute-path>"
        exit 1
    fi

    if [[ "$full_path" != /* ]]; then
        echo "Error: path must be absolute"
        exit 1
    fi

    if [ ! -e "$full_path" ]; then
        echo "Error: $full_path does not exist"
        exit 1
    fi

    load_config
    select_config_for_repo "$repo_arg"
    require_source_exists "$SELECTED_SOURCE_DIR"

    if ! path_is_under_target "$full_path" "$SELECTED_TARGET_DIR"; then
        echo "Error: path must be under configured target: $SELECTED_TARGET_DIR"
        exit 1
    fi

    # Extract relative path from the target directory and convert / to # so
    # nested files can be stored flat in the selected source directory.
    relative_path=$(relative_path_from_target "$full_path" "$SELECTED_TARGET_DIR")
    dotfile_name="${relative_path//\//#}"
    dotfile_path="$SELECTED_SOURCE_DIR/$dotfile_name"

    if [ -e "$dotfile_path" ]; then
        echo "Error: $dotfile_path already exists in dotfiles"
        exit 1
    fi

    cp -R "$full_path" "$dotfile_path"
    echo "Copied $full_path -> $dotfile_path"

    read -p "Remove original at $full_path? [y/N] " confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        rm -rf "$full_path"
        echo "Removed $full_path"
    else
        echo "Skipped removal of $full_path"
    fi

    cmd_link --repo "$SELECTED_SOURCE_DIR"
}

cmd_doctor() {
    local repo_arg=""

    while [ "$#" -gt 0 ]; do
        case "$1" in
            --repo)
                if [ -z "${2:-}" ]; then
                    echo "Usage: dfman doctor [--repo <source>]"
                    exit 1
                fi
                repo_arg="$2"
                shift 2
                ;;
            --repo=*)
                repo_arg="${1#--repo=}"
                if [ -z "$repo_arg" ]; then
                    echo "Usage: dfman doctor [--repo <source>]"
                    exit 1
                fi
                shift
                ;;
            *)
                echo "Usage: dfman doctor [--repo <source>]"
                exit 1
                ;;
        esac
    done

    load_config
    if [ -n "$repo_arg" ]; then
        select_config_for_repo "$repo_arg"
        require_source_exists "$SELECTED_SOURCE_DIR"
        find "$SELECTED_SOURCE_DIR" -type l ! -exec test -e {} \; -print
    else
        require_all_sources_exist

        local source_dir
        for source_dir in "${CONFIG_SOURCES[@]}"; do
            find "$source_dir" -type l ! -exec test -e {} \; -print
        done
    fi
}

cmd_repo_add() {
    if [ "$#" -lt 1 ] || [ "$#" -gt 2 ]; then
        echo "Usage: dfman repo-add <source> [target]"
        exit 1
    fi

    local source_arg="$1"
    local target_arg="${2:-~}"
    local source_dir
    local target_dir
    local config_dir

    validate_config_value "$source_arg" "source"
    validate_config_value "$target_arg" "target"

    source_dir=$(normalize_dir "$(expand_home "$source_arg")")
    target_dir=$(normalize_dir "$(expand_home "$target_arg")")

    validate_config_path "$source_dir" "source" "source argument"
    validate_config_path "$target_dir" "target" "target argument"

    if [ ! -d "$source_dir" ]; then
        echo "Error: source directory does not exist: $source_dir"
        exit 1
    fi

    if [ ! -d "$target_dir" ]; then
        echo "Error: target directory does not exist: $target_dir"
        exit 1
    fi

    if config_entry_exists "$source_dir" "$target_dir"; then
        echo "Source already configured: $source_arg -> $target_arg"
        return
    fi

    config_dir=$(dirname "$CONFIG_FILE")
    mkdir -p "$config_dir"

    if [ -s "$CONFIG_FILE" ] && [ -n "$(tail -c 1 "$CONFIG_FILE")" ]; then
        printf '\n' >> "$CONFIG_FILE"
    fi

    if [ "$#" -eq 2 ]; then
        printf '%s %s\n' "$source_arg" "$target_arg" >> "$CONFIG_FILE"
        echo "Added source: $source_arg -> $target_arg"
    else
        printf '%s\n' "$source_arg" >> "$CONFIG_FILE"
        echo "Added source: $source_arg -> ~"
    fi
}

cmd_repo_rm() {
    if [ "$#" -ne 1 ]; then
        echo "Usage: dfman repo-rm <source>"
        exit 1
    fi

    local source_arg="$1"
    local source_to_remove
    local temp_file
    local line
    local stripped_line
    local line_number=0
    local source_dir
    local target_dir
    local extra
    local removed_count=0

    validate_config_value "$source_arg" "source"

    source_to_remove=$(normalize_dir "$(expand_home "$source_arg")")
    validate_config_path "$source_to_remove" "source" "source argument"

    if [ ! -f "$CONFIG_FILE" ]; then
        echo "Error: config file not found: $CONFIG_FILE"
        exit 1
    fi

    temp_file=$(mktemp "$CONFIG_FILE.XXXXXX")

    while IFS= read -r line || [ -n "$line" ]; do
        line_number=$((line_number + 1))
        stripped_line="${line%%#*}"
        read -r source_dir target_dir extra <<< "$stripped_line"

        if [ -z "$source_dir" ]; then
            printf '%s\n' "$line" >> "$temp_file"
            continue
        fi

        if [ -n "$extra" ]; then
            rm -f "$temp_file"
            echo "Error: too many fields in $CONFIG_FILE:$line_number"
            exit 1
        fi

        source_dir=$(normalize_dir "$(expand_home "$source_dir")")
        if [ -z "$target_dir" ]; then
            target_dir="~"
        fi
        target_dir=$(normalize_dir "$(expand_home "$target_dir")")

        validate_config_path "$source_dir" "source" "$CONFIG_FILE:$line_number"
        validate_config_path "$target_dir" "target" "$CONFIG_FILE:$line_number"

        if [ "$source_dir" = "$source_to_remove" ]; then
            removed_count=$((removed_count + 1))
            continue
        fi

        printf '%s\n' "$line" >> "$temp_file"
    done < "$CONFIG_FILE"

    if [ "$removed_count" -eq 0 ]; then
        rm -f "$temp_file"
        echo "Error: repo is not configured: $source_arg"
        exit 1
    fi

    mv "$temp_file" "$CONFIG_FILE"

    if [ "$removed_count" -eq 1 ]; then
        echo "Removed source: $source_arg"
    else
        echo "Removed $removed_count sources: $source_arg"
    fi
}

sync_repo_source() {
    local source_dir="$1"
    local commit_message
    local diff_status

    echo "Syncing repo: $source_dir"

    if [ ! -d "$source_dir" ]; then
        echo -e "\033[33mWarning: source directory does not exist: $source_dir\033[0m"
        return 1
    fi

    if ! git -C "$source_dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        echo -e "\033[33mWarning: source is not a git repo: $source_dir\033[0m"
        return 1
    fi

    if ! git -C "$source_dir" add -A; then
        echo -e "\033[33mWarning: failed to stage changes in $source_dir\033[0m"
        return 1
    fi

    if git -C "$source_dir" diff --cached --quiet; then
        echo "No local changes to commit"
    else
        diff_status=$?
        if [ "$diff_status" -ne 1 ]; then
            echo -e "\033[33mWarning: failed to inspect staged changes in $source_dir\033[0m"
            return 1
        fi

        commit_message="Auto-Sync ($(date '+%Y-%m-%d %H:%M:%S'))"
        if ! git -C "$source_dir" commit -m "$commit_message"; then
            echo -e "\033[33mWarning: failed to commit changes in $source_dir\033[0m"
            return 1
        fi
    fi

    if ! git -C "$source_dir" pull --rebase; then
        echo -e "\033[33mWarning: pull failed in $source_dir; resolve conflicts or git state manually, then retry\033[0m"
        return 1
    fi

    if ! git -C "$source_dir" push; then
        echo -e "\033[33mWarning: push failed in $source_dir\033[0m"
        return 1
    fi
}

cmd_repo_sync() {
    local repo_arg=""
    local failed=false

    while [ "$#" -gt 0 ]; do
        case "$1" in
            --repo)
                if [ -z "${2:-}" ]; then
                    echo "Usage: dfman repo-sync [--repo <source>]"
                    exit 1
                fi
                repo_arg="$2"
                shift 2
                ;;
            --repo=*)
                repo_arg="${1#--repo=}"
                if [ -z "$repo_arg" ]; then
                    echo "Usage: dfman repo-sync [--repo <source>]"
                    exit 1
                fi
                shift
                ;;
            *)
                echo "Usage: dfman repo-sync [--repo <source>]"
                exit 1
                ;;
        esac
    done

    load_config
    if [ -n "$repo_arg" ]; then
        select_config_for_repo "$repo_arg"
        if ! sync_repo_source "$SELECTED_SOURCE_DIR"; then
            exit 1
        fi
        return
    fi

    local source_dir
    for source_dir in "${CONFIG_SOURCES[@]}"; do
        if ! sync_repo_source "$source_dir"; then
            failed=true
        fi
    done

    if [ "$failed" = true ]; then
        exit 1
    fi
}

cmd_self_update() {
    if ! command -v wget >/dev/null 2>&1; then
        echo "Error: wget is required for self-update"
        exit 1
    fi

    local script_path
    local temp_dir
    local temp_file
    local first_line

    script_path=$(current_executable_path)
    temp_dir=$(mktemp -d)
    temp_file="$temp_dir/dfman"

    if ! wget -q -O "$temp_file" "$DFMAN_UPDATE_URL"; then
        rm -rf "$temp_dir"
        echo "Error: failed to download dfman from $DFMAN_UPDATE_URL"
        exit 1
    fi

    read -r first_line < "$temp_file" || true
    if [ ! -s "$temp_file" ] || [ "$first_line" != "#!/bin/bash" ]; then
        rm -rf "$temp_dir"
        echo "Error: downloaded update does not look like dfman"
        exit 1
    fi

    if cmp -s "$temp_file" "$script_path"; then
        rm -rf "$temp_dir"
        echo "dfman is already up to date"
        return
    fi

    if ! install -m 0755 "$temp_file" "$script_path"; then
        rm -rf "$temp_dir"
        echo "Error: failed to install update to $script_path"
        exit 1
    fi

    rm -rf "$temp_dir"
    echo "Updated dfman at $script_path"
}

case "${1:-}" in
    link)
        shift
        cmd_link "$@"
        ;;
    create)
        shift
        cmd_create "$@"
        ;;
    doctor)
        shift
        cmd_doctor "$@"
        ;;
    repo-add)
        shift
        cmd_repo_add "$@"
        ;;
    repo-rm)
        shift
        cmd_repo_rm "$@"
        ;;
    repo-sync)
        shift
        cmd_repo_sync "$@"
        ;;
    self-update)
        cmd_self_update
        ;;
    -h|--help)
        usage
        ;;
    "")
        usage
        ;;
    *)
        echo "Unknown command: $1"
        usage
        ;;
esac
